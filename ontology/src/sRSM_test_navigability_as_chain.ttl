@prefix : <https://cdm.ovh/rsm/topology/topo#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dul: <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix list: <https://cdm.ovh/rsm/list2/list2#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rgeo: <https://cdm.ovh/rsm/geosparql_adapter/rgeo#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix topo: <https://cdm.ovh/rsm/topology/topo#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://cdm.ovh/rsm/topology/topo> .

<https://cdm.ovh/rsm/topology/topo> rdf:type owl:Ontology ;
                                     owl:versionIRI <https://cdm.ovh/rsm/topology/1.0rc9/topo> ;
                                     owl:imports <https://cdm.ovh/rsm/geosparql_adapter/rgeo> ;
                                     dc:abstract "RSM topology provides fundamental railway network description, focused on connections and navigabilities between net elements. Net elements can be linear (embodied by lines or tracks) or non linear (embodied by stations, yards, or wider network areas). Geometry aspects are delegated to GeoSPARQL and are not essential to topology. Functional aspects (such as \"current switch setting\") also are not part of the topology."@en ;
                                     dc:contributor "Pierre Tane, UIC"@en ;
                                     dc:creator "Airy Magnien, UIC"@en ;
                                     dc:date "28 May 2026"@en ;
                                     dc:description """Full RSM topology. Connexities and Navigabilities as object properties . Additionally, navigability reification is included. Temporal aspects to be covered by annotations and/or named graphs and/or dul:Situations, or similar.

Syntactic sugar: some properties that are most likely to be used are chained properties, equivalent to derived associations in UML."""@en ;
                                     dc:title "RSM topology"@en ;
                                     dc:type "RDF/OWL ontology (using OWL2 RL profile)"@en ;
                                     dcterms:license <https://creativecommons.org/licenses/by-sa/4.0/> ;
                                     owl:versionInfo "1.0rc8 : Existential restriction added on fromPort and toPort properties."@en ,
                                                     """1.0rc9:
navigableFromTransitive characteristic \"transitive\" was missing.
LeadsTo renamed LeadsToNext and LeadsToTransitive to LeadsTo (which, by the way, is not transitive).
property chain removed (likely cause of reasoner crashes)"""@en ,
                                                     "Reification limited to navigableTo property. Added property oppositePort as a property chain, and related properties."@en ,
                                                     "error correction: navigableFromTransitive was not marked transitive"@en ;
                                     <https://vocab.org/vann/preferredNamespacePrefix> "topo" ;
                                     <https://vocab.org/vann/preferredNamespaceURI> "http://cdm.ovh/rsm/topology/topo#"@en .

